# Google Maps JavaScript API — https://console.cloud.google.com/
# Used for: map preview on lead cards
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Used for: bot protection on login/register forms
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Lemon Squeezy checkout URLs — https://app.lemonsqueezy.com/products
# Create products/variants first, then paste the checkout URLs below
NUXT_PUBLIC_LS_PRO_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
NUXT_PUBLIC_LS_ANNUAL_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
NUXT_PUBLIC_LS_CREDITS_50_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
NUXT_PUBLIC_LS_CREDITS_200_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
NUXT_PUBLIC_LS_CREDITS_500_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
