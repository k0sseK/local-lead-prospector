# Database (auto-configured by Docker Compose)
DATABASE_URL=postgresql://llp_user:llp_password@db:5432/llp_db

# Google Places API (New) — https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Gemini AI — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Resend email delivery — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Resend — verified sender address (must match your verified domain in Resend)
RESEND_FROM_EMAIL=you@yourdomain.com

# Lemon Squeezy — https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
