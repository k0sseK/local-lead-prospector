# Database (auto-configured by Docker Compose)
DATABASE_URL=postgresql://llp_user:llp_password@db:5432/llp_db

# Google Places API (New) — https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Gemini AI — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Resend email delivery — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Resend — verified sender address (must match your verified domain in Resend)
RESEND_FROM_EMAIL=you@yourdomain.com

# Lemon Squeezy — https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here

# Lemon Squeezy — variant IDs for plans and credit packs
# Find variant IDs at: https://app.lemonsqueezy.com/products
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_ANNUAL_VARIANT_ID=
LEMONSQUEEZY_CREDITS_50_VARIANT_ID=
LEMONSQUEEZY_CREDITS_200_VARIANT_ID=
LEMONSQUEEZY_CREDITS_500_VARIANT_ID=

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Redis — used for rate limiting and Celery task queue
# Railway: set this to the Redis service's REDIS_URL variable
REDIS_URL=redis://localhost:6379/0

# Playwright scraper microservice (optional — SPA fallback)
# Leave empty to disable; backend falls back to httpx-only scraping
# Railway: http://${{playwright-service.RAILWAY_PRIVATE_DOMAIN}}:8001
PLAYWRIGHT_SERVICE_URL=http://localhost:8001
PLAYWRIGHT_API_SECRET=your-internal-secret
